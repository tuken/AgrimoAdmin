PORT=3000
NODE_ENV=development

# Session
SESSION_SECRET=change-me
SESSION_NAME=agri.sid
SESSION_TABLE=sessions
# If you want the library to auto-create the sessions table, set true.
# In production, managing DDL explicitly is recommended.
SESSION_CREATE_TABLE=false
SESSION_COOKIE_MAXAGE_MS=604800000
SESSION_EXPIRATION_MS=604800000
SESSION_CHECK_EXPIRATION_MS=900000

# Upstream GraphQL
GRAPHQL_ENDPOINT=http://18.182.21.218:8080/
# GRAPHQL_API_KEY=

# MySQL (sessions + users)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=pass
DB_NAME=agrimo
DB_CHARSET=utf8mb4

# Password hashing
BCRYPT_SALT_ROUNDS=10
