<%
  const currentRoleId = user ? (user.role_id ?? user.roleId ?? user.roleID ?? user.role_type ?? user.roleType ?? '') : '';
  const isOwnerUser = Number(currentRoleId) === 2;
%>
<%- include('../partials/head', { title: "ユーザー一覧", pageCss: "user", bodyClass: "" }) %>
<%- include('../partials/header') %>

<main>
<div class="container">
<section class="card">
      <header class="page-header">
        <div class="page-title-group">
          <div class="page-title-eyebrow">Users</div>
          <h1 class="page-title">ユーザー管理</h1>
          <div class="page-title-sub">ユーザーの情報を一元管理</div>
        </div>
        <div class="page-header-actions">
          <button class="primary-button btn-main-green" type="button" id="new-user-button">
            <span class="icon">＋</span>
            <span>ユーザーを追加</span>
          </button>
        </div>
      </header>

      <!-- 検索＆件数表示 -->
<div class="user-list-header">
  <div class="user-list-header-title">
    <span id="user-count"></span>
  </div>
  <div class="user-search-wrapper">
    <!-- <div class="search-field">
      <span class="search-icon">🔍</span>
      <input
        id="user-search"
        class="search-input"
        type="text"
        placeholder="氏名・メールアドレスで検索"
        autocomplete="off"
      >
      <button class="search-clear" id="user-search-clear" type="button">×</button>
    </div> -->
  </div>
</div>


      <!-- 作業者カード一覧 -->
      <div class="report-list user-list user-sections" id="user-list" data-current-user-id="<%= user && user.id ? user.id : "" %>" data-current-role-id="<%= user ? (user.role_id ?? user.roleId ?? user.roleID ?? user.role_type ?? user.roleType ?? "") : "" %>">

        <!-- オーナーセクション -->
        <% if (!isOwnerUser) { %>
        <section class="user-section" data-section="owner">
          <h2 class="user-section-heading">オーナー</h2>
        </section>
        <% } %>

        <!-- 作業者セクション -->
        <section class="user-section" data-section="worker">
          <h2 class="user-section-heading">作業者</h2>
        </section>
      </div>
      <!-- 作業者一覧 ページネーション -->
      <div class="pagination" id="user-pagination">
        <button type="button" id="user-page-prev">前へ</button>
        <span id="user-page-info">1 / 1ページ</span>
        <button type="button" id="user-page-next">次へ</button>
      </div>

    </section>
</div>
</main>

<%- include('../partials/footer') %>


  <!-- ▼ 作業者 新規追加モーダル（user_list.html 互換） -->
  <div class="modal-backdrop" id="new-user-modal-backdrop" aria-hidden="true">
    <div class="modal" role="dialog" aria-modal="true" aria-labelledby="new-user-modal-title">
      <header class="modal-header">
        <div class="modal-title-group">
          <div class="modal-title" id="new-user-modal-title">ユーザーを追加</div>
          <div class="modal-subtitle">氏名・メールアドレスを設定します。</div>
        </div>
        <button class="modal-close-btn" type="button" id="new-user-modal-close">×</button>
      </header>

      <div class="modal-body">
        <div class="detail-grid">
          <div class="detail-form-group" id="new-user-owner-checkbox-group" style="grid-column:1/-1;">
            <label class="detail-label" for="new-user-owner">オーナー</label>
            <div>
              <label style="display:inline-flex;align-items:center;gap:6px;">
                <input type="checkbox" id="new-user-owner">
                <span>オーナーとして登録する</span>
              </label>
            </div>
          </div>
          <div class="detail-form-group" id="new-user-farm-name-group" style="grid-column:1/-1;">
            <label class="detail-label" for="new-user-farm-name">法人名</label>
            <input id="new-user-farm-name" class="detail-input" type="text" placeholder="例）株式会社〇〇ファーム">
          </div>
          <div class="detail-form-group">
            <label class="detail-label" for="new-user-last-name">姓</label>
            <input id="new-user-last-name" class="detail-input" type="text" placeholder="例）佐藤">
          </div>
          <div class="detail-form-group">
            <label class="detail-label" for="new-user-first-name">名</label>
            <input id="new-user-first-name" class="detail-input" type="text" placeholder="例）花子">
          </div>
          <div class="detail-form-group">
            <label class="detail-label" for="new-user-email">メールアドレス</label>
            <input id="new-user-email" class="detail-input" type="email" placeholder="例）hanako@example.com">
          </div>
          <div class="detail-form-group">
            <label class="detail-label" for="new-user-password">パスワード</label>
            <input id="new-user-password" class="detail-input" type="password" placeholder="初期パスワード" minlength="8" maxlength="20">
            <div class="detail-help">8文字以上20文字以下の半角英数字で入力してください。記号は !.-=_#@&lt;&gt; が使用できます。</div>
          </div>
          <div class="detail-form-group">
            <label class="detail-label" for="new-user-postal-code">郵便番号</label>
            <input id="new-user-postal-code" class="detail-input" type="text" inputmode="numeric" placeholder="例）0000001">
          </div>
          <div class="detail-form-group" style="grid-column:1/-1;">
            <label class="detail-label" for="new-user-address">住所</label>
            <input id="new-user-address" class="detail-input" type="text" >
          </div>
          <div class="detail-form-group">
            <label class="detail-label" for="new-user-gender">性別</label>
            <select id="new-user-gender" class="detail-select">
              <option value="">選択してください</option>
              <option value="male">男性</option>
              <option value="female">女性</option>
              <option value="other">その他</option>
              <!-- <option value="unknown">未回答</option> -->
            </select>
          </div>
          <div class="detail-form-group">
            <label class="detail-label" for="new-user-birthday">生年月日</label>
            <input id="new-user-birthday" class="detail-input" type="date">
          </div>
          <div class="detail-form-group" style="grid-column:1/-1;">
            <label class="detail-label" for="new-user-note">備考</label>
            <textarea id="new-user-note" class="detail-textarea" rows="4" placeholder="補足事項があれば入力してください"></textarea>
          </div>


          <div class="detail-form-group" id="owner-select-wrapper">
            <label class="detail-label" for="new-user-owner-select">所属オーナー</label>
            <select id="new-user-owner-select" class="detail-select">
              <option value="">オーナーを選択</option>
            </select>
          </div>

          <div class="detail-form-group" id="new-user-fields-group" style="grid-column:1/-1;">
            <label class="detail-label">紐づく圃場</label>
            <div class="field-selector">
              <div class="field-selector-row">
                <select id="new-field-select" class="detail-select">
                  <option value="">圃場を選択</option>
                </select>
                <button class="btn-secondary small" type="button" id="new-field-add">追加</button>
              </div>
              <div class="chip-list" id="new-field-chips"></div>
            </div>
          </div>
        </div>
      </div>

      <footer class="detail-footer">
        <div class="detail-footer-left"></div>
        <div class="detail-footer-right">
          <button class="btn-secondary" type="button" id="new-user-cancel">キャンセル</button>
          <button class="btn-primary btn-main-green" type="button" id="new-user-save">登録する</button>
        </div>
      </footer>
    </div>
  </div>

  <!-- ▼ 作業者 詳細モーダル（編集対応） -->
  <div class="modal-backdrop" id="user-detail-modal-backdrop" aria-hidden="true">
    <div class="modal" role="dialog" aria-modal="true" aria-labelledby="user-detail-modal-title">
      <header class="modal-header">
        <div class="modal-title-group">
          <div class="modal-title" id="user-detail-modal-title">ユーザー詳細</div>
          <div class="modal-subtitle" id="user-detail-modal-subtitle"></div>
        </div>
        <button class="modal-close-btn" type="button" id="user-detail-modal-close">×</button>
      </header>

      <div class="modal-body">
        <div class="detail-grid">
          <div class="detail-form-group" id="detail-user-farm-name-group">
            <label class="detail-label" for="detail-user-farm-name">法人名</label>
            <input id="detail-user-farm-name" class="detail-input" type="text" disabled>
          </div>
          <div class="detail-form-group">
            <label class="detail-label" for="detail-user-last-name">姓</label>
            <input id="detail-user-last-name" class="detail-input" type="text" disabled>
          </div>
          <div class="detail-form-group">
            <label class="detail-label" for="detail-user-first-name">名</label>
            <input id="detail-user-first-name" class="detail-input" type="text" disabled>
          </div>
          <div class="detail-form-group">
            <label class="detail-label" for="detail-user-email">メールアドレス</label>
            <input id="detail-user-email" class="detail-input" type="email" disabled>
          </div>
          <div class="detail-form-group" id="detail-user-password-group" style="display:none;">
            <label class="detail-label" for="detail-user-password">パスワード</label>
            <input id="detail-user-password" class="detail-input" type="password" placeholder="変更する場合のみ入力" minlength="8" maxlength="20" disabled>
            <div class="detail-help">8文字以上20文字以下の半角英数字で入力してください。記号は !.-=_#@&lt;&gt; が使用できます。</div>
          </div>
          <div class="detail-form-group">
            <label class="detail-label" for="detail-user-postal-code">郵便番号</label>
            <input id="detail-user-postal-code" class="detail-input" type="text" disabled>
          </div>
          <div class="detail-form-group" style="grid-column:1/-1;">
            <label class="detail-label" for="detail-user-address">住所</label>
            <input id="detail-user-address" class="detail-input" type="text" disabled>
          </div>
          <div class="detail-form-group">
            <label class="detail-label" for="detail-user-gender">性別</label>
            <select id="detail-user-gender" class="detail-select" disabled>
              <option value="">選択してください</option>
              <option value="male">男性</option>
              <option value="female">女性</option>
              <option value="other">その他</option>
              <!-- <option value="unknown">未回答</option> -->
            </select>
          </div>
          <div class="detail-form-group">
            <label class="detail-label" for="detail-user-birthday">生年月日</label>
            <input id="detail-user-birthday" class="detail-input" type="date" disabled>
          </div>
          <div class="detail-form-group" style="grid-column:1/-1;">
            <label class="detail-label" for="detail-user-note">備考</label>
            <textarea id="detail-user-note" class="detail-textarea" rows="4" disabled></textarea>
          </div>

          <div class="detail-form-group">
            <label class="detail-label" for="detail-user-owner">オーナー</label>
            <div>
              <label style="display:inline-flex;align-items:center;gap:6px;">
                <input type="checkbox" id="detail-user-owner" disabled>
                <span>オーナー</span>
              </label>
            </div>
          </div>

          <div class="detail-form-group" id="detail-owner-select-wrapper">
            <label class="detail-label" for="detail-user-owner-select">所属オーナー</label>
            <select id="detail-user-owner-select" class="detail-select" disabled>
              <option value="">オーナーを選択</option>
            </select>
          </div>

          <div class="detail-form-group" style="grid-column:1/-1;">
            <label class="detail-label">紐づく圃場</label>
            <div class="field-selector" id="detail-field-selector" style="display:none; margin-bottom:8px;">
              <div class="field-selector-row">
                <select id="detail-field-select" class="detail-select" disabled>
                  <option value="">先に所属オーナーを選択</option>
                </select>
                <button class="btn-secondary small" type="button" id="detail-field-add">追加</button>
              </div>
            </div>
            <div class="chip-list" id="detail-field-chips"></div>
          </div>

          <div class="detail-form-group">
            <label class="detail-label" for="detail-user-last-login">最終ログイン</label>
            <input id="detail-user-last-login" class="detail-input" type="text" disabled>
          </div>
          <div class="detail-form-group">
            <label class="detail-label" for="detail-user-created-at">登録日時</label>
            <input id="detail-user-created-at" class="detail-input" type="text" disabled>
          </div>
        </div>
      </div>

      <footer class="detail-footer">
        <div class="detail-footer-left">
          ID: <span id="detail-user-id">-</span>
        </div>
        <div class="detail-footer-right">
          <button class="btn-secondary" type="button" id="user-detail-cancel" style="display:none;">キャンセル</button>
          <button class="btn-danger" type="button" id="user-detail-delete" style="display:none;">
            <span class="icon">🗑</span>削除
          </button>
          <button class="btn-primary btn-main-green" type="button" id="user-detail-save" style="display:none;">保存する</button>
          <button class="btn-primary btn-main-green" type="button" id="user-detail-edit">
            <span class="btn-icon">✏</span>編集
          </button>
        </div>
      </footer>
    </div>
  </div>



<%- include('../partials/scripts', { pageJs: "user" }) %>
