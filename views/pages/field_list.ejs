<%- include('../partials/head', { title: "圃場一覧", pageCss: "field", bodyClass: "" }) %>
<%- include('../partials/header') %>

<% const isRole1 = (user && Number(user.role_id) === 1); %>

<main>
<div class="container">
      <section class="card" aria-label="圃場一覧">
        <header class="page-header">
          <div>
            <div class="page-title">圃場一覧</div>
            <div class="page-subtitle">
              登録されている圃場の一覧です。カードをクリックすると詳細を表示します。
            </div>
          </div>

          <div class="page-header-actions">
            <% if (isRole1) { %>
              <button class="primary-button btn-main-green" id="field-create-button" type="button">
                <span class="icon">＋</span>
                <span>圃場を登録</span>
              </button>
            <% } %>

            <!-- オーナー絞り込み -->
            <% if (isRole1) { %>
              <div class="select-wrapper">
                <select id="owner-filter">
                  <option value="">すべてのオーナー</option>
                </select>
              </div>
            <% } %>

            <div class="select-wrapper">
              <select id="field-type-filter">
                <option value="">すべての種別</option>
                <option value="paddy">水田</option>
                <option value="upland">畑（畑地）</option>
                <option value="vegetable">野菜圃場</option>
                <option value="fruit">果樹園</option>
                <option value="greenhouse">ハウス圃場</option>
                <option value="other">その他</option>
              </select>
            </div>

            <div class="select-wrapper">
              <select id="field-status-filter">
                <option value="">すべての状態</option>
                <option value="active">利用中</option>
                <option value="inactive">一時休止</option>
                <option value="abandoned">廃止</option>
              </select>
            </div>

            <!-- <div class="search-input-wrapper">
              <span class="search-icon">🔍</span>
              <input
                type="text"
                id="field-search"
                placeholder="圃場名・住所<%= isRole1 ? '・オーナー名' : '' %>などで検索"
              >
              <span class="clear-icon" id="field-search-clear">✕</span>
            </div> -->
          </div>
        </header>

        <header class="list-header-row">
          <div class="list-header-title">圃場一覧</div>
          <div class="list-header-meta" id="list-header-meta">6件表示</div>
        </header>

        <section class="fields-grid" id="fields-grid" data-user-id="<%= user && user.id ? user.id : '' %>">
          <div class="loading-message" id="fields-loading" style="display:none; padding: 16px; color:#6b7280;">圃場一覧を取得中…</div>
          <!-- 圃場カードは JavaScript で生成 -->
        </section>
        <!-- 圃場一覧 ページネーション -->
        <div class="pagination" id="field-pagination">
          <button type="button" id="field-page-prev">前へ</button>
          <span id="field-page-info">1 / 1ページ</span>
          <button type="button" id="field-page-next">次へ</button>
        </div>

        <div class="empty-message" id="empty-message" style="display:none;">
          条件に合致する圃場がありません。
        </div>

      </section>
    </div>
</main>

<!-- 圃場登録モーダル（role1のみボタン表示。モーダル自体は常にDOMに置く） -->
<div class="field-modal-backdrop" id="field-create-backdrop" aria-hidden="true">
  <div class="field-modal" role="dialog" aria-modal="true" aria-labelledby="field-create-title">
    <div class="field-modal-header">
      <div>
        <div class="field-modal-title" id="field-create-title">圃場を登録</div>
        <div class="field-modal-subtitle">新しい圃場を追加します</div>
      </div>
      <button type="button" class="field-modal-close-btn" id="field-create-close" aria-label="閉じる">×</button>
    </div>

    <div class="field-modal-body">
      <!-- left: map (簡易) -->
      <div>
        <div class="field-modal-section-title">位置</div>
        <div class="map-container" id="field-create-map-container">
          <iframe class="map-frame" id="field-create-map-frame" title="圃場位置" loading="lazy" referrerpolicy="no-referrer-when-downgrade"></iframe>
          <div class="map-marker" id="field-create-map-marker" aria-label="位置マーカー"></div>
        </div>
        <div class="map-coords" id="field-create-map-coords">lat: -, lng: -</div>
        <div class="field-hint" style="margin-top:10px; font-size:12px; color:#6b7280;">※緯度/経度を入力すると地図が更新されます</div>
      </div>

      <!-- right: form -->
      <div>
        <div class="field-modal-section-title">基本情報</div>

        <div class="detail-form-group">
          <label class="detail-label">圃場名</label>
          <input class="detail-input" id="create-name" type="text" placeholder="例：6号圃場（北側）">
        </div>

        <div class="detail-form-group" style="display:none;">
          <label class="detail-label">コード</label>
          <input class="detail-input" id="create-code" type="text" placeholder="例：F-006-N" tabindex="-1" aria-hidden="true">
        </div>

        <div class="detail-form-group">
          <label class="detail-label">面積（㎡）</label>
          <input class="detail-input" id="create-area" type="number" step="0.01" placeholder="例：1200">
        </div>

        <div class="detail-inline-row">
          <div class="detail-form-group">
            <label class="detail-label">種別</label>
            <select class="detail-input" id="create-type">
              <option value="paddy">水田</option>
              <option value="upland">畑（畑地）</option>
              <option value="vegetable">野菜圃場</option>
              <option value="fruit">果樹園</option>
              <option value="greenhouse">ハウス圃場</option>
              <option value="other">その他</option>
            </select>
          </div>
          <div class="detail-form-group">
            <label class="detail-label">状態</label>
            <select class="detail-input" id="create-status">
              <option value="active">利用中</option>
              <option value="inactive">一時休止</option>
              <option value="abandoned">廃止</option>
            </select>
          </div>
        </div>

        <div class="detail-form-group">
          <label class="detail-label">オーナー</label>
          <select class="detail-input" id="create-owner"><option value="">選択してください</option></select>
        </div>

        <div class="detail-form-group">
          <label class="detail-label">郵便番号</label>
          <input class="detail-input" id="create-postal" type="text" inputmode="numeric" autocomplete="postal-code" placeholder="例：0000001">
        </div>

        <div class="detail-form-group">
          <label class="detail-label">住所</label>
          <input class="detail-input" id="create-address" type="text" autocomplete="street-address" placeholder="例：東京都渋谷区...">
        </div>

        <div class="detail-form-group">
          <label class="detail-label">緯度 / 経度</label>
          <div class="detail-inline-row" style="gap:8px;">
            <input class="detail-input" id="create-lat" type="number" step="0.0000001" placeholder="lat">
            <input class="detail-input" id="create-lng" type="number" step="0.0000001" placeholder="lng">
          </div>
        </div>

        <div class="detail-form-group">
          <label class="detail-label">備考</label>
          <textarea class="detail-textarea" id="create-note" placeholder="メモ"></textarea>
        </div>
      </div>
    </div>

    <div class="field-modal-footer">
      <div class="field-modal-footer-left">
        <button type="button" class="btn-secondary" id="field-create-cancel">キャンセル</button>
      </div>
      <div class="field-modal-footer-right">
        <button type="button" class="btn-primary-sm btn-main-green" id="field-create-save">登録</button>
      </div>
    </div>
  </div>
</div>

<!-- 圃場詳細モーダル（圃場ページ専用。共通アカウントモーダルとCSS衝突しない） -->
<div class="field-modal-backdrop" id="field-detail-backdrop" aria-hidden="true">
  <div class="field-modal" role="dialog" aria-modal="true" aria-labelledby="field-detail-title">
    <div class="field-modal-header">
      <div>
        <div class="field-modal-title" id="field-detail-title">圃場詳細</div>
        <div class="field-modal-subtitle" id="field-detail-subtitle">コード: -</div>
      </div>
      <button type="button" class="field-modal-close-btn" id="field-detail-close" aria-label="閉じる">×</button>
    </div>

    <div class="field-modal-body">
      <!-- left: map / workers -->
      <div>
        <div class="field-modal-section-title">位置</div>
        <div class="map-container" id="field-map-container">
          <iframe class="map-frame" id="field-map-frame" title="圃場位置" loading="lazy" referrerpolicy="no-referrer-when-downgrade"></iframe>
          <div class="map-marker" id="field-map-marker" aria-label="位置マーカー"></div>
        </div>
        <div class="map-coords" id="field-map-coords">lat: -, lng: -</div>

      </div>

      <!-- right: detail -->
      <div>
        <div class="field-modal-section-title">基本情報</div>
        <input type="hidden" id="detail-id" />

        <div class="detail-form-group">
          <label class="detail-label">圃場名</label>
          <input class="detail-input" id="detail-name" type="text" disabled>
        </div>

        <div class="detail-form-group">
          <label class="detail-label">面積（㎡）</label>
          <input class="detail-input" id="detail-area" type="number" step="0.01" disabled>
        </div>

        <div class="detail-inline-row">
          <div class="detail-form-group">
            <label class="detail-label">種別</label>
            <select class="detail-input" id="detail-type" disabled></select>
          </div>
          <div class="detail-form-group">
            <label class="detail-label">状態</label>
            <select class="detail-input" id="detail-status" disabled></select>
          </div>
        </div>

        <div class="detail-form-group">
          <label class="detail-label">オーナー</label>
          <input class="detail-input" id="detail-owner" type="text" disabled>
        </div>

        <div class="detail-form-group">
          <label class="detail-label">郵便番号</label>
          <input class="detail-input" id="detail-postal" type="text" disabled>
        </div>

        <div class="detail-form-group">
          <label class="detail-label">住所</label>
          <input class="detail-input" id="detail-address" type="text" disabled>
        </div>
      </div>
    </div>

    <div class="field-modal-footer">
      <div class="field-modal-footer-left">
        <button type="button" class="btn-secondary" id="field-detail-cancel">閉じる</button>
      </div>
      <div class="field-modal-footer-right">
        <button type="button" class="btn-secondary" id="field-detail-edit">編集</button>
        <button type="button" class="btn-primary-sm btn-main-green" id="field-detail-save" style="display:none;">保存</button>
      </div>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>
<%- include('../partials/scripts', { pageJs: "field" }) %>
