<%- include('../partials/head', { title: "圃場一覧", pageCss: "field", bodyClass: "" }) %>
<%- include('../partials/header') %>

<% const isRole1 = (user && Number(user.role_id) === 1); %>

<main>
<div class="container">
      <section class="card" aria-label="圃場一覧">
        <header class="page-header">
          <div>
            <div class="page-title">圃場一覧</div>
            <div class="page-subtitle">
              登録されている圃場の一覧です。名称・住所・種別・状態・オーナーで絞り込みできます。カードをクリックすると詳細を表示します。
            </div>
          </div>

          <div class="page-header-actions">
            <% if (isRole1) { %>
              <button class="primary-button" id="field-create-button" type="button">
                <span class="icon">＋</span>
                <span>圃場を登録</span>
              </button>
            <% } %>

            <!-- オーナー絞り込み -->
            <% if (isRole1) { %>
              <div class="select-wrapper">
                <select id="owner-filter">
                  <option value="">すべてのオーナー</option>
                  <option value="山田農園">山田農園</option>
                  <option value="佐藤ファーム">佐藤ファーム</option>
                  <option value="高橋アグリサービス">高橋アグリサービス</option>
                </select>
              </div>
            <% } %>

            <div class="select-wrapper">
              <select id="field-type-filter">
                <option value="">すべての種別</option>
                <option value="paddy">水田</option>
                <option value="upland">畑（畑地）</option>
                <option value="vegetable">野菜圃場</option>
                <option value="fruit">果樹園</option>
                <option value="greenhouse">ハウス圃場</option>
                <option value="other">その他</option>
              </select>
            </div>

            <div class="select-wrapper">
              <select id="field-status-filter">
                <option value="">すべての状態</option>
                <option value="active">利用中</option>
                <option value="inactive">一時休止</option>
                <option value="abandoned">廃止</option>
              </select>
            </div>

            <div class="search-input-wrapper">
              <span class="search-icon">🔍</span>
              <input
                type="text"
                id="field-search"
                placeholder="圃場名・住所<%= isRole1 ? '・オーナー名' : '' %>などで検索"
              >
              <span class="clear-icon" id="field-search-clear">✕</span>
            </div>
          </div>
        </header>

