          <div class="detail-grid">
            <div class="detail-form-group">
              <label class="detail-label" for="edit-field">圃場</label>
              <select id="edit-field" class="detail-select" name="field_id">
                <option value="">選択してください</option>
                <% ((user && user.fields) ? user.fields : []).forEach((f) => { %>
                  <option value="<%= f.id %>"><%= f.name %></option>
                <% }) %>
              </select>
            </div>

            <div class="detail-form-group">
              <label class="detail-label" for="edit-date">日付</label>
              <input id="edit-date" class="detail-input" type="date" name="date" required>
            </div>

            <div class="detail-form-group">
