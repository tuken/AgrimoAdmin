              <select id="edit-task" class="detail-select" name="task" required>
                <option value="">選択してください</option>
                <option value="施肥">施肥</option>
                <option value="灌水">灌水</option>
                <option value="収穫">収穫</option>
                <option value="除草">除草</option>
                <option value="防除（農薬散布）">防除（農薬散布）</option>
                <option value="その他">その他</option>
              </select>
            </div>

            <div class="detail-form-group">
              <label class="detail-label" for="edit-owner">担当者</label>
              <input id="edit-owner" class="detail-input" type="text" name="owner">
            </div>

            <div class="detail-form-group">
              <label class="detail-label" for="edit-field">圃場</label>
              <input id="edit-field" class="detail-input" type="text" name="field">
            </div>

            <div class="detail-form-group">
              <label class="detail-label" for="edit-worker">作業者（人数）</label>
              <input id="edit-worker" class="detail-input" type="text" name="worker">
            </div>

            <div class="detail-form-group">
              <label class="detail-label" for="edit-weather">天候</label>
              <input id="edit-weather" class="detail-input" type="text" name="weather">
            </div>

            <div class="detail-form-group">
              <label class="detail-label" for="edit-time-hours">作業時間（h）</label>
              <div class="time-duration-wrapper">
                <input id="edit-time-hours" class="detail-input time-hours-input" type="number" step="0.25" min="0" name="hours">
                <span class="time-duration-unit">h</span>
              </div>
            </div>

            <div class="detail-form-group">
              <label class="detail-label">画像</label>
              <label class="detail-image-upload-label" for="edit-image-file">
                <span class="icon">📷</span> 画像を選択
              </label>
              <input id="edit-image-file" class="detail-image-upload-input" type="file" accept="image/*">
            </div>
          </div>
        </form>
      </div>
    </div>

    <footer class="detail-footer">
      <div class="detail-footer-left" id="edit-message"></div>
      <div class="detail-footer-right">
        <button class="btn-secondary" type="button" id="edit-cancel" data-modal-close>キャンセル</button>
        <button class="btn-primary" type="button" id="edit-save">
          <span class="btn-icon">💾</span>
          保存する
        </button>
      </div>
    </footer>
  </div>
</div>


  </div>
</main>

<%- include('../partials/footer') %>
<%- include('../partials/scripts', { pageJs: "report" }) %>
