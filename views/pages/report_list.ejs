<!-- 日報モーダル群（report_list.html のダイアログレイアウトに合わせる） -->

<!-- 日報詳細モーダル -->
<div class="modal-backdrop" id="detail-modal-backdrop" aria-hidden="true">
  <div class="modal" id="detail-modal" role="dialog" aria-modal="true" aria-labelledby="detail-modal-title">
    <header class="modal-header">
      <div class="modal-title-group">
        <div class="modal-title" id="detail-modal-title">日報詳細</div>
        <div class="modal-subtitle" id="detail-modal-subtitle">登録済みの日報を確認できます。</div>
      </div>
      <button class="modal-close-btn" type="button" id="detail-modal-close" data-modal-close>×</button>
    </header>

    <div class="modal-body">
      <div>
        <div class="detail-section-title">作業の様子</div>
        <div class="detail-image-wrapper">
          <img id="detail-image" src="/img/agri-login-bg.png" alt="作業画像（詳細）">
        </div>
        <div class="detail-note">
          <label class="detail-label" for="detail-note-text">作業内容</label>
          <textarea id="detail-note-text" disabled></textarea>
        </div>
      </div>

      <div>
        <div class="detail-section-title">日報情報</div>
        <div class="detail-grid">
          <div class="detail-form-group">
            <label class="detail-label" for="detail-date">日付</label>
            <input id="detail-date" class="detail-input" type="date" disabled>
          </div>

          <div class="detail-form-group">
            <label class="detail-label" for="detail-task">作業カテゴリ</label>
            <select id="detail-task" class="detail-select" disabled>
              <option value="">選択してください</option>
              <option value="施肥">施肥</option>
              <option value="灌水">灌水</option>
              <option value="収穫">収穫</option>
              <option value="除草">除草</option>
              <option value="防除（農薬散布）">防除（農薬散布）</option>
              <option value="その他">その他</option>
            </select>
          </div>

          <div class="detail-form-group">
            <label class="detail-label" for="detail-owner">担当者</label>
            <input id="detail-owner" class="detail-input" type="text" disabled>
          </div>

          <div class="detail-form-group">
            <label class="detail-label" for="detail-field">圃場</label>
            <input id="detail-field" class="detail-input" type="text" disabled>
          </div>

          <div class="detail-form-group">
            <label class="detail-label" for="detail-worker">作業者（人数）</label>
            <input id="detail-worker" class="detail-input" type="text" disabled>
          </div>

          <div class="detail-form-group">
            <label class="detail-label" for="detail-weather">天候</label>
            <input id="detail-weather" class="detail-input" type="text" disabled>
          </div>

          <div class="detail-form-group">
            <label class="detail-label" for="detail-time-hours">作業時間（h）</label>
            <div class="time-duration-wrapper">
              <input id="detail-time-hours" class="detail-input time-hours-input" type="number" step="0.25" min="0" disabled>
              <span class="time-duration-unit">h</span>
            </div>
          </div>

          <div class="detail-form-group">
            <label class="detail-label" for="detail-updated-at">最終更新</label>
            <input id="detail-updated-at" class="detail-input" type="text" disabled>
          </div>
        </div>
      </div>
    </div>

    <footer class="detail-footer">
      <div class="detail-footer-left" id="detail-meta-footer"></div>
      <div class="detail-footer-right">
        <button class="btn-secondary" type="button" id="detail-cancel" data-modal-close style="display:none;">閉じる</button>
        <button class="btn-danger" type="button" id="detail-delete" style="display:none;">
          <span class="icon">🗑</span>
          削除
        </button>
        <% if (!isRole1) { %>
          <button class="btn-primary" type="button" id="detail-edit">
            <span class="btn-icon">✏</span>
            編集
          </button>
        <% } %>
      </div>
    </footer>
  </div>
</div>

<!-- 新規登録モーダル -->
<div class="modal-backdrop" id="new-modal-backdrop" aria-hidden="true">
  <div class="modal" id="new-modal" role="dialog" aria-modal="true" aria-labelledby="new-modal-title">
    <header class="modal-header">
      <div class="modal-title-group">
        <div class="modal-title" id="new-modal-title">日報を新規登録</div>
        <div class="modal-subtitle" id="new-modal-subtitle">作業内容を入力し、新しい日報として登録します。</div>
      </div>
      <button class="modal-close-btn" type="button" id="new-modal-close" data-modal-close>×</button>
    </header>

    <div class="modal-body">
      <div>
        <div class="detail-section-title">作業の様子</div>
        <div class="detail-image-wrapper">
          <img id="new-image" src="/img/agri-login-bg.png" alt="作業画像（新規）">
        </div>
        <div class="detail-note">
          <label class="detail-label" for="new-note-text">作業内容</label>
          <textarea id="new-note-text"></textarea>
        </div>
      </div>

      <div>
        <div class="detail-section-title">日報情報</div>
        <form id="report-create-form">
          <div class="detail-grid">
            <div class="detail-form-group">
              <label class="detail-label" for="new-date">日付</label>
              <input id="new-date" class="detail-input" type="date" name="date" required>
            </div>

            <div class="detail-form-group">
              <label class="detail-label" for="new-task">作業カテゴリ</label>
              <select id="new-task" class="detail-select" name="task" required>
                <option value="">選択してください</option>
                <option value="施肥">施肥</option>
                <option value="灌水">灌水</option>
                <option value="収穫">収穫</option>
                <option value="除草">除草</option>
                <option value="防除（農薬散布）">防除（農薬散布）</option>
                <option value="その他">その他</option>
              </select>
            </div>

            <div class="detail-form-group">
              <label class="detail-label" for="new-owner">担当者</label>
              <input id="new-owner" class="detail-input" type="text" name="owner">
            </div>

            <div class="detail-form-group">
              <label class="detail-label" for="new-field">圃場</label>
              <input id="new-field" class="detail-input" type="text" name="field">
            </div>

            <div class="detail-form-group">
              <label class="detail-label" for="new-worker">作業者（人数）</label>
              <input id="new-worker" class="detail-input" type="text" name="worker">
            </div>

            <div class="detail-form-group">
              <label class="detail-label" for="new-weather">天候</label>
              <input id="new-weather" class="detail-input" type="text" name="weather">
            </div>

            <div class="detail-form-group">
              <label class="detail-label" for="new-time-hours">作業時間（h）</label>
              <div class="time-duration-wrapper">
                <input id="new-time-hours" class="detail-input time-hours-input" type="number" step="0.25" min="0" name="hours">
                <span class="time-duration-unit">h</span>
              </div>
            </div>

            <div class="detail-form-group">
              <label class="detail-label">画像</label>
              <label class="detail-image-upload-label" for="new-image-file">
                <span class="icon">📷</span> 画像を選択
              </label>
              <input id="new-image-file" class="detail-image-upload-input" type="file" accept="image/*">
            </div>
          </div>
        </form>
      </div>
    </div>

    <footer class="detail-footer">
      <div class="detail-footer-left" id="new-message"></div>
      <div class="detail-footer-right">
        <button class="btn-secondary" type="button" id="new-cancel" data-modal-close>キャンセル</button>
        <button class="btn-primary" type="button" id="new-save">
          <span class="btn-icon">💾</span>
          登録する
        </button>
      </div>
    </footer>
  </div>
</div>

<!-- 編集モーダル -->
<div class="modal-backdrop" id="edit-modal-backdrop" aria-hidden="true">
  <div class="modal" id="edit-modal" role="dialog" aria-modal="true" aria-labelledby="edit-modal-title">
    <header class="modal-header">
      <div class="modal-title-group">
        <div class="modal-title" id="edit-modal-title">日報を編集</div>
        <div class="modal-subtitle" id="edit-modal-subtitle">内容を編集して保存します。</div>
      </div>
      <button class="modal-close-btn" type="button" id="edit-modal-close" data-modal-close>×</button>
    </header>

    <div class="modal-body">
      <div>
        <div class="detail-section-title">作業の様子</div>
