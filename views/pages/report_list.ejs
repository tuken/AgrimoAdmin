<%- include('../partials/head', { title: "日報一覧", pageCss: "report", bodyClass: "" }) %>
<%- include('../partials/header') %>

<% const isRole1 = (user && Number(user.role_id) === 1); %>

<main>
  <div class="container">
<section class="card">
      <header class="page-header">
        <div class="page-title-group">
          <div class="page-title-eyebrow">Daily Reports</div>
          <h1 class="page-title">日報管理</h1>
          <div class="page-title-sub">カレンダーと連動した日報の一覧・検索・編集</div>
        </div>
        <div class="page-header-actions">
          <% if (!isRole1) { %>
            <button class="primary-button btn-main-green" type="button" id="new-report-button">
              <span class="icon">＋</span>
              <span>日報を登録</span>
            </button>
          <% } %>
        </div>
      </header>

      <div class="layout">
        <!-- カレンダー -->
        <section class="calendar-card">
          <!-- <header class="calendar-header">
            <div class="calendar-title-group">
              <div class="calendar-title-main">
                <span>作業カレンダー</span>
                <span class="badge-inline">
                  <span>📅</span><span>クリックで日別絞り込み</span>
                </span>
              </div>
              <div class="calendar-sub">日報と連動したカレンダーです。日付をクリックすると、その日の作業だけを一覧で確認できます。</div>
            </div>
            <div class="calendar-nav">
              <button class="calendar-arrow" id="prev-month" type="button">◀</button>
              <div class="calendar-month-label" id="current-month-label">2025年 12月</div>
              <button class="calendar-arrow" id="next-month" type="button">▶</button>
            </div>
          </header> -->
<header class="panel-header">
  <div class="panel-header-main">
    <div class="panel-title"><span class="panel-title-icon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><rect x="3.5" y="5" width="17" height="15.5" rx="4" stroke="currentColor" stroke-width="1.6"/><path d="M7.5 3.75V6.25" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/><path d="M16.5 3.75V6.25" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/><path d="M3.5 9.25H20.5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/><rect x="7.25" y="12" width="3.25" height="3.25" rx="1" fill="currentColor" opacity="0.9"/></svg></span>作業カレンダー</div>
    <div class="calendar-sub">
      日報と連動したカレンダーです。日付をクリックすると、その日の作業だけを一覧で確認できます。
    </div>
  </div>

  <div class="calendar-nav">
    <button class="calendar-arrow" id="prev-month" type="button">◀</button>

    <div class="calendar-month-label" id="current-month-label">
      2025年 12月
    </div>

    <button class="calendar-arrow" id="next-month" type="button">▶</button>
    <button class="calendar-today-btn" id="current-month-button" type="button">今月へ</button>

    <!-- ▼ 年月プルダウン（クリックで開く小パネル） -->
    <div class="year-month-picker" id="year-month-picker" hidden>
      <select id="year-select"></select>
      <select id="month-select">
        <option value="0">1月</option>
        <option value="1">2月</option>
        <option value="2">3月</option>
        <option value="3">4月</option>
        <option value="4">5月</option>
        <option value="5">6月</option>
        <option value="6">7月</option>
        <option value="7">8月</option>
        <option value="8">9月</option>
        <option value="9">10月</option>
        <option value="10">11月</option>
        <option value="11">12月</option>
      </select>
      <button type="button" id="apply-year-month">適用</button>
    </div>
  </div>
</header>

          <div class="calendar-grid" id="calendar-grid">
            <div class="calendar-weekdays">
              <div class="calendar-weekday sun">日</div>
              <div class="calendar-weekday">月</div>
              <div class="calendar-weekday">火</div>
              <div class="calendar-weekday">水</div>
              <div class="calendar-weekday">木</div>
              <div class="calendar-weekday">金</div>
              <div class="calendar-weekday sat">土</div>
            </div>
            <div class="calendar-days" id="calendar-days">
              <!-- JavaScriptで生成 -->
            </div>
          </div>

          <footer class="calendar-footer">
            <button class="calendar-filter active" id="filter-all" type="button">
              <span>当月の日報を表示</span>
            </button>
            <div class="calendar-legend">
              <span class="legend-dot"></span>
              <span>日報のある日</span>
            </div>
          </footer>
        </section>

        <!-- 日報一覧 -->
        <section class="reports-card">
          <header class="reports-header">
            <div class="reports-header-left">
              <div class="reports-title" id="list-header-title">日報一覧</div>
              <div class="reports-meta" id="list-header-meta">
                当月の最近の作業が新しい順に表示されます。
              </div>
            </div>
            <div class="reports-header-right">
              <!--
              <div class="search-row">
                <div class="search-field">
                  <span class="search-icon">🔍</span>
                  <input
                    id="report-search"
                    class="search-input"
                    type="text"
                    placeholder="作業内容・メモなどで検索"
                  >
                  <button class="search-clear" id="report-search-clear" type="button">×</button>
                </div>
              </div>
              -->
              <div class="filter-row">
                <span class="filter-label">絞り込み：</span>
                <% if (isRole1) { %>
                  <div class="task-select-wrapper">
                    <select id="owner-filter">
                      <option value="">すべてのオーナー</option>
                      
                    </select>
                  </div>
                <% } %>
                <div class="task-select-wrapper">
                  <select id="field-filter">
                    <option value="">すべての圃場</option>
                    <% ((user && user.fields) ? user.fields : []).forEach((f) => { %>
                      <option value="<%= f.id %>"><%= f.name %></option>
                    <% }) %>
                  </select>
                </div>
                <div class="task-select-wrapper">
                  <select id="task-filter">
                    <option value="">すべての作業</option>
                    <% (workTypes || []).slice().sort((a,b) => Number(a.id) - Number(b.id)).forEach((t) => { %>
                      <option value="<%= t.name %>"><%= t.name %></option>
                    <% }) %>
                  </select>
                </div>
              </div>
            </div>
          </header>

          <div class="reports-list" id="reports-list" data-user-id="<%= user && user.id ? user.id : '' %>">
            <div class="empty-message" id="empty-message" style="display:none;">
              条件に一致する日報がありません。絞り込み条件を見直してください。
            </div>
            <div class="loading-message" id="reports-loading" style="display:none; padding: 12px 0; color:#6b7280;">日報一覧を取得中…</div>
            <div class="reports-grid">
              <!-- 日報カードは JavaScript で生成 -->
            </div>

            <div class="pagination" id="pagination">
              <button type="button" id="page-prev">前へ</button>
              <span id="page-info">1 / 2</span>
              <button type="button" id="page-next">次へ</button>
            </div>
          </div>
        </section>
      </div>
    </section>


<!-- 日報モーダル群（report_list.html のダイアログレイアウトに合わせる） -->

<!-- 日報詳細モーダル -->
<div class="modal-backdrop" id="detail-modal-backdrop" aria-hidden="true">
  <div class="modal" id="detail-modal" role="dialog" aria-modal="true" aria-labelledby="detail-modal-title">
    <header class="modal-header">
      <div class="modal-title-group">
        <div class="modal-title" id="detail-modal-title">日報詳細</div>
        <div class="modal-subtitle" id="detail-modal-subtitle">登録済みの日報を確認できます。</div>
      </div>
      <button class="modal-close-btn" type="button" id="detail-modal-close" data-modal-close>×</button>
    </header>

    <div class="modal-body">
      <div>
        <div class="detail-section-title">作業の様子</div>
        <div class="detail-image-wrapper detail-image-wrapper--optional is-empty" id="detail-image-wrapper">
          <img id="detail-image" alt="作業画像（詳細）" hidden>
          <div class="detail-image-placeholder" id="detail-image-placeholder">
            <div class="detail-image-placeholder-icon">🌾</div>
            <div class="detail-image-placeholder-text">作業画像は未登録です</div>
          </div>
        </div>
        <div class="detail-note">
          <label class="detail-label" for="detail-note-text">作業内容</label>
          <textarea id="detail-note-text" disabled></textarea>
        </div>
      </div>

      <div>
        <div class="detail-section-title">日報情報</div>
        <div class="detail-grid">
          <div class="detail-form-group">
            <label class="detail-label" for="detail-date">日付</label>
            <input id="detail-date" class="detail-input" type="date" disabled>
          </div>

          <div class="detail-form-group">
            <label class="detail-label" for="detail-task">作業カテゴリ</label>
            <select id="detail-task" class="detail-select" disabled>
              <option value="">選択してください</option>
              <% (workTypes || []).slice().sort((a,b) => Number(a.id) - Number(b.id)).forEach((t) => { %>
                <option value="<%= t.id %>"><%= t.name %></option>
              <% }) %>
            </select>
          </div>

          <div class="detail-form-group">
            <label class="detail-label" for="detail-crop-item">作付品目</label>
            <select id="detail-crop-item" class="detail-select" disabled>
              <option value="">選択してください</option>
              <% (cropItems || []).slice().sort((a,b) => Number(a.id) - Number(b.id)).forEach((c) => { %>
                <option value="<%= c.id %>"><%= c.name %></option>
              <% }) %>
            </select>
          </div>

          <div class="detail-form-group">
            <label class="detail-label" for="detail-crop-variety">品種</label>
            <input id="detail-crop-variety" class="detail-input" type="text" disabled>
          </div>

          <div class="detail-form-group">
            <label class="detail-label" for="detail-owner">担当者</label>
            <input id="detail-owner" class="detail-input" type="text" disabled>
          </div>

          <div class="detail-form-group">
            <label class="detail-label" for="detail-field">圃場</label>
            <select id="detail-field" class="detail-select" disabled>
              <option value="">選択してください</option>
              <% ((user && user.fields) ? user.fields : []).forEach((f) => { %>
                <option value="<%= f.id %>"><%= f.name %></option>
              <% }) %>
            </select>
          </div>

          <div class="detail-form-group">
            <label class="detail-label" for="detail-weather">天候</label>
            <select id="detail-weather" class="detail-select" disabled>
              <option value="">選択してください</option>
              <% (weatherCodes || []).forEach((w) => { %>
                <option value="<%= w.code %>"><%= w.japanese %></option>
              <% }) %>
            </select>
          </div>

          <div class="detail-form-group">
            <label class="detail-label" for="detail-time-hours">作業時間（h）</label>
            <div class="time-duration-wrapper">
              <input id="detail-time-hours" class="detail-input time-hours-input" type="number" step="0.25" min="0" disabled>
              <span class="time-duration-unit">h</span>
            </div>
          </div>

          <div class="detail-form-group">
            <label class="detail-label" for="detail-updated-at">最終更新</label>
            <input id="detail-updated-at" class="detail-input" type="text" disabled>
          </div>
        </div>
      </div>
    </div>

    <footer class="detail-footer">
      <div class="detail-footer-left" id="detail-meta-footer"></div>
      <div class="detail-footer-right">
        <button class="btn-secondary" type="button" id="detail-cancel" data-modal-close style="display:none;">閉じる</button>
        <button class="btn-danger" type="button" id="detail-delete" style="display:none;">
          <span class="icon">🗑</span>
          削除
        </button>
        <% if (!isRole1) { %>
          <button class="btn-primary btn-main-green" type="button" id="detail-edit">
            <span class="btn-icon">✏</span>
            編集
          </button>
        <% } %>
      </div>
    </footer>
  </div>
</div>

<!-- 画像拡大モーダル -->
<div class="modal-backdrop image-viewer-backdrop" id="image-viewer-backdrop" aria-hidden="true">
  <div class="image-viewer-modal" role="dialog" aria-modal="true" aria-label="画像拡大表示">
    <button class="image-viewer-close" type="button" data-modal-close aria-label="閉じる">×</button>
    <img id="image-viewer-image" src="" alt="拡大画像">
  </div>
</div>

<!-- 新規登録モーダル -->
<div class="modal-backdrop" id="new-modal-backdrop" aria-hidden="true">
  <div class="modal" id="new-modal" role="dialog" aria-modal="true" aria-labelledby="new-modal-title">
    <header class="modal-header">
      <div class="modal-title-group">
        <div class="modal-title" id="new-modal-title">日報を新規登録</div>
        <div class="modal-subtitle" id="new-modal-subtitle">作業内容を入力し、新しい日報として登録します。</div>
      </div>
      <button class="modal-close-btn" type="button" id="new-modal-close" data-modal-close>×</button>
    </header>

    <div class="modal-body">
      <div>
        <div class="detail-section-title">作業の様子</div>
        <div class="detail-image-wrapper detail-image-wrapper--optional is-empty" id="new-image-wrapper">
          <img id="new-image" alt="作業画像（新規）" hidden>
          <div class="detail-image-placeholder" id="new-image-placeholder"><div class="detail-image-placeholder-icon">🌾</div><div class="detail-image-placeholder-text">画像は未選択です</div></div>
        </div>
        <div class="detail-note">
          <label class="detail-label" for="new-note-text">作業内容</label>
          <textarea id="new-note-text"></textarea>
        </div>
      </div>

      <div>
        <div class="detail-section-title">日報情報</div>
        <form id="report-create-form">
          <div class="detail-grid">
            <div class="detail-form-group">
              <label class="detail-label" for="new-field">圃場</label>
              <select id="new-field" class="detail-select" name="field_id">
                <option value="" <%= ((user && user.fields) ? user.fields : []).length !== 1 ? 'selected' : '' %>>選択してください</option>
                <% ((user && user.fields) ? user.fields : []).forEach((f) => { %>
                  <option value="<%= f.id %>" <%= ((user && user.fields) ? user.fields : []).length === 1 ? 'selected' : '' %>><%= f.name %></option>
                <% }) %>
              </select>
            </div>

            <div class="detail-form-group">
              <label class="detail-label" for="new-date">日付</label>
              <input id="new-date" class="detail-input" type="date" name="date" required>
            </div>

            <div class="detail-form-group">
              <label class="detail-label" for="new-task">作業カテゴリ</label>
              <select id="new-task" class="detail-select" name="task" required>
                <option value="">選択してください</option>
                <% (workTypes || []).slice().sort((a,b) => Number(a.id) - Number(b.id)).forEach((t) => { %>
                  <option value="<%= t.id %>"><%= t.name %></option>
                <% }) %>
              </select>
            </div>

            <div class="detail-form-group">
              <label class="detail-label" for="new-crop-item">作付品目</label>
              <select id="new-crop-item" class="detail-select" name="crop_item_id">
                <option value="">選択してください</option>
                <% (cropItems || []).slice().sort((a,b) => Number(a.id) - Number(b.id)).forEach((c) => { %>
                  <option value="<%= c.id %>"><%= c.name %></option>
                <% }) %>
              </select>
            </div>

            <div class="detail-form-group">
              <label class="detail-label" for="new-crop-variety">品種</label>
              <select id="new-crop-variety" class="detail-select" name="crop_variety_id" disabled>
                <option value="">作付品目を選択してください</option>
              </select>
            </div>

            <div class="detail-form-group">
              <label class="detail-label" for="new-owner">担当者</label>
              <input id="new-owner" class="detail-input" type="text" value="<%= user ? `${user.last_name || ''} ${user.first_name || ''}`.trim() : '' %>" disabled>
              <input type="hidden" id="new-owner-id" name="owner_id" value="<%= user ? user.id : '' %>">
            </div>

            <div class="detail-form-group">
              <label class="detail-label" for="new-weather">天候</label>
              <select id="new-weather" class="detail-select" name="weather">
                <option value="">選択してください</option>
                <% (weatherCodes || []).forEach((w) => { %>
                  <option value="<%= w.code %>"><%= w.japanese %></option>
                <% }) %>
              </select>
            </div>

            <div class="detail-form-group">
              <label class="detail-label" for="new-time-hours">作業時間（h）</label>
              <div class="time-duration-wrapper">
                <input id="new-time-hours" class="detail-input time-hours-input" type="number" step="0.25" min="0" name="hours">
                <span class="time-duration-unit">h</span>
              </div>
            </div>

            <div class="detail-form-group">
              <label class="detail-label">画像</label>
              <label class="detail-image-upload-label" for="new-image-file">
                <span class="icon">📷</span> 画像を選択
              </label>
              <input id="new-image-file" class="detail-image-upload-input" type="file" accept="image/*">
            </div>
          </div>
        </form>
      </div>
    </div>

    <footer class="detail-footer">
      <div class="detail-footer-left" id="new-message"></div>
      <div class="detail-footer-right">
        <button class="btn-secondary" type="button" id="new-cancel" data-modal-close>キャンセル</button>
        <button class="btn-primary btn-main-green" type="button" id="new-save">
          <span class="btn-icon">💾</span>
          登録する
        </button>
      </div>
    </footer>
  </div>
</div>

<!-- 編集モーダル -->
<div class="modal-backdrop" id="edit-modal-backdrop" aria-hidden="true">
  <div class="modal" id="edit-modal" role="dialog" aria-modal="true" aria-labelledby="edit-modal-title">
    <header class="modal-header">
      <div class="modal-title-group">
        <div class="modal-title" id="edit-modal-title">日報を編集</div>
        <div class="modal-subtitle" id="edit-modal-subtitle">内容を編集して保存します。</div>
      </div>
      <button class="modal-close-btn" type="button" id="edit-modal-close" data-modal-close>×</button>
    </header>

    <div class="modal-body">
      <div>
        <div class="detail-section-title">作業の様子</div>
        <div class="detail-image-wrapper detail-image-wrapper--optional is-empty" id="edit-image-wrapper">
          <img id="edit-image" alt="作業画像（編集）" hidden>
          <div class="detail-image-placeholder" id="edit-image-placeholder"><div class="detail-image-placeholder-icon">🌾</div><div class="detail-image-placeholder-text">画像は未選択です</div></div>
        </div>
        <div class="detail-note">
          <label class="detail-label" for="edit-note-text">作業内容</label>
          <textarea id="edit-note-text"></textarea>
        </div>
      </div>

      <div>
        <div class="detail-section-title">日報情報</div>
