              </select>
            </div>

            <div class="detail-form-group">
              <label class="detail-label" for="edit-crop-item">作付品目</label>
              <select id="edit-crop-item" class="detail-select" name="crop_item_id">
                <option value="">選択してください</option>
                <% (cropItems || []).slice().sort((a,b) => Number(a.id) - Number(b.id)).forEach((c) => { %>
                  <option value="<%= c.id %>"><%= c.name %></option>
                <% }) %>
              </select>
            </div>

            <div class="detail-form-group">
              <label class="detail-label" for="edit-crop-variety">品種</label>
              <select id="edit-crop-variety" class="detail-select" name="crop_variety_id" disabled>
                <option value="">作付品目を選択してください</option>
              </select>
            </div>

            <div class="detail-form-group">
              <label class="detail-label" for="edit-owner">担当者</label>
              <input id="edit-owner" class="detail-input" type="text" value="<%= user ? `${user.last_name || ''} ${user.first_name || ''}`.trim() : '' %>" disabled>
              <input type="hidden" id="edit-owner-id" name="owner_id" value="<%= user ? user.id : '' %>">
            </div>

            <div class="detail-form-group">
              <label class="detail-label" for="edit-weather">天候</label>
              <select id="edit-weather" class="detail-select" name="weather">
                <option value="">選択してください</option>
                <% (weatherCodes || []).forEach((w) => { %>
                  <option value="<%= w.code %>"><%= w.japanese %></option>
                <% }) %>
              </select>
            </div>

            <div class="detail-form-group">
              <label class="detail-label" for="edit-time-hours">作業時間（h）</label>
              <div class="time-duration-wrapper">
                <input id="edit-time-hours" class="detail-input time-hours-input" type="number" step="0.25" min="0" name="hours">
                <span class="time-duration-unit">h</span>
              </div>
            </div>

            <div class="detail-form-group">
              <label class="detail-label">画像</label>
              <label class="detail-image-upload-label" for="edit-image-file">
                <span class="icon">📷</span> 画像を選択
              </label>
              <input id="edit-image-file" class="detail-image-upload-input" type="file" accept="image/*">
            </div>
          </div>
        </form>
      </div>
    </div>

